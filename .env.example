# Copiar a .env.local y completar con el proyecto Firebase de UCU

# URL canónica del sitio (producción: https://ucu.org.ar). Usada en sitemap, Open Graph y JSON-LD.
NEXT_PUBLIC_APP_URL=http://localhost:9005

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ucuweb-2887d.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ucuweb-2887d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ucuweb-2887d.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Service account recomendado (ej. en C:/SECRETS/)
GOOGLE_APPLICATION_CREDENTIALS=C:/SECRETS/ucuweb-2887d-firebase-adminsdk-fbsvc-8af2cb7a61.json
FIREBASE_PROJECT_ID=ucuweb-2887d
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@ucuweb-2887d.iam.gserviceaccount.com

# Alternativa: pegar private key en lugar de GOOGLE_APPLICATION_CREDENTIALS
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Observatorio de fallos (API externa; luego se puede migrar a Firestore)
OBSERVATORIO_API_URL=https://vps-3844415-x.dattaweb.com/observatorio-api

# Reclamos — SQL Server v0021348_ucu_v2 (Usuarios Protegidos)
# Datos de conexión: DonWeb → Bases de datos → v0021348_ucu_v2 → credenciales / acceso remoto
RECLAMOS_SQL_SERVER=200.58.120.182
RECLAMOS_SQL_PORT=1433
RECLAMOS_SQL_DATABASE=v0021348_ucu_v2
RECLAMOS_SQL_USER=v0021348_ucu_v2
RECLAMOS_SQL_PASSWORD=
RECLAMOS_SQL_SCHEMA=con
RECLAMOS_SQL_TRUST_CERT=true
# RECLAMOS_SQL_ENCRYPT=true

# Google AI Studio — Contestación de oficios (Gemini)
GEMINI_API_KEY=
# Opcional; por defecto gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Panel admin (/admin)
# Login con Google: habilitar proveedor Google en Firebase Console → Authentication
ADMIN_PANEL_EMAIL=abengolea1@gmail.com
# ADMIN_ALLOWED_EMAILS=otro@ejemplo.com,admin@ucu.org.ar
ADMIN_PANEL_PASSWORD=definir_contraseña_segura
ADMIN_SESSION_SECRET=generar_con_openssl_rand_hex_32
